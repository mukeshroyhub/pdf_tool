{
  "name": "pdfforge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"pnpm --filter @pdfforge/api dev\" \"pnpm --filter @pdfforge/web dev\"",
    "dev:api": "pnpm --filter @pdfforge/api dev",
    "dev:web": "pnpm --filter @pdfforge/web dev",
    "build": "pnpm --filter @pdfforge/web build",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "test:e2e": "playwright test",
    "db:migrate": "pnpm --filter @pdfforge/api db:setup",
    "setup": "node scripts/setup-local.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
