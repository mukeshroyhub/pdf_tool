# Copy this to `.env` on the VM and fill in the real values.
# Keep this file secret — never commit the real .env.

# ── Public URL (your domain, HTTPS) ─────────────────────────────
# Both must be your real domain. HTTPS is required so secure login
# cookies work.
WEB_URL=https://pdftool.example.com
API_URL=https://pdftool.example.com

# ── Database: your existing Neon connection string ──────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# ── Auth secrets: generate two random 40+ char strings ──────────
# On the VM you can generate them with:  openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-a-random-40-plus-character-secret
JWT_REFRESH_SECRET=replace-with-another-random-40-plus-character-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ── File storage: your existing Supabase (S3-compatible) bucket ─
STORAGE_DRIVER=s3
S3_BUCKET=pdfforge-files
S3_REGION=us-east-1
S3_ENDPOINT=https://cpseztzafaclmfmdtwsy.storage.supabase.co/storage/v1/s3
S3_ACCESS_KEY_ID=your-supabase-access-key-id
S3_SECRET_ACCESS_KEY=your-supabase-secret-access-key
S3_FORCE_PATH_STYLE=true

# ── Optional: email (Brevo/Resend) and Google OAuth ─────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="PDF Tool <no-reply@pdftool.example.com>"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
