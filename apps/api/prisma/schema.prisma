// PDFForge database schema.
// Dev uses SQLite; production uses PostgreSQL (run `node scripts/use-postgres.mjs`
// from the repo root to switch the provider; Docker then runs `prisma db push`).
// All types below are portable between SQLite and PostgreSQL.

generator client {
  provider   = "prisma-client-js"
  // Engine-less (Rust-free) client: queries run through the WASM query
  // compiler and a JS driver adapter (libsql in dev, pg in production).
  engineType = "client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String? // null for OAuth-only accounts
  googleId      String?  @unique
  avatarUrl     String?
  emailVerified Boolean  @default(false)
  storageUsed   BigInt   @default(0) // bytes
  storageLimit  BigInt   @default(1073741824) // 1 GiB free tier
  activityLogging Boolean @default(true) // when false, no activity is recorded
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  refreshTokens RefreshToken[]
  actionTokens  ActionToken[]
  files         File[]
  activities    Activity[]

  @@map("users")
}

// Rotating refresh tokens; only a SHA-256 hash is stored.
model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?
  ip        String?

  @@index([userId])
  @@map("refresh_tokens")
}

// Single-use tokens for email verification and password reset.
// `type` is "EMAIL_VERIFY" | "PASSWORD_RESET" (string, not enum, for SQLite portability).
model ActionToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  type      String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, type])
  @@map("action_tokens")
}

// User files (populated from Phase 2 onward; schema defined now for stability).
model File {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  mimeType   String
  sizeBytes  BigInt
  storageKey String     @unique // path on disk or S3 object key
  pageCount  Int?
  isFavorite Boolean    @default(false)
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  activities Activity[]

  @@index([userId, createdAt])
  @@map("files")
}

// Activity timeline entries. `action` examples: "UPLOAD", "MERGE", "COMPRESS".
model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileId    String?
  file      File?    @relation(fields: [fileId], references: [id], onDelete: SetNull)
  action    String
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("activities")
}
