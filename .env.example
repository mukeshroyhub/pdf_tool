# ── API ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000

# SQLite in dev; for PostgreSQL use e.g. postgresql://pdfforge:pdfforge@localhost:5432/pdfforge
DATABASE_URL="file:./dev.db"

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Google OAuth (optional — endpoints return 503 until configured)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP (optional — in dev, emails are logged to the API console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="PDF Tool <no-reply@pdfforge.local>"
